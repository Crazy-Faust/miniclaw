# --- LLM provider selection (REQUIRED — pick one) ---
# One of: anthropic | openai | gemini  (default: anthropic)
# MINICLAW_PROVIDER=anthropic

# Set the API key for whichever provider you're using:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Override the model (default depends on provider):
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o-mini
#   gemini    → gemini-2.0-flash
# MINICLAW_MODEL=

# OpenAI provider only: point at any OpenAI-compatible server.
# MINICLAW_BASE_URL=http://localhost:11434/v1     # Ollama
# MINICLAW_BASE_URL=http://localhost:1234/v1      # LM Studio

# --- Data + sandbox ---
# Where the SQLite DB, daemon socket, PID file, and daemon logs live.
# MINICLAW_HOME=/path/to/data                     # default: ~/.miniclaw

# Filesystem sandbox root for read_file / list_directory / write_file /
# apply_patch / shell / browser_screenshot. Also where AGENTS.md and
# TOOLS.md are looked up for prompt injection.
# MINICLAW_WORKSPACE=/Users/you/projects/sandbox  # default: process.cwd()

# --- Daemon (Phase 1, optional) ---
# Override the daemon's Unix socket path (clients connect here for `miniclaw chat`).
# MINICLAW_SOCKET=$HOME/.miniclaw/miniclaw.sock

# Override the daemon's PID file path.
# MINICLAW_PID=$HOME/.miniclaw/miniclaw.pid

# --- Web / search skills (Phase 2, optional) ---
# Comma-separated origins fetch_url is allowed to call. Unset = no allowlist.
# MINICLAW_WEB_ALLOWLIST=https://example.com,https://docs.example.org

# If set, the web_search skill is registered. The provider plugin chooses the backend.
# MINICLAW_SEARCH_API_KEY=
# MINICLAW_SEARCH_PROVIDER=

# --- Transports (Phase 3, optional) ---
# Discord bot token. If set, the daemon starts the Discord transport on
# `miniclaw daemon run`. Requires the optional peer dep: `pnpm add -w discord.js`.
# MINICLAW_DISCORD_TOKEN=Mzk...
